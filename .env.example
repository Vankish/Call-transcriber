# Supabase — claves PUBLICABLES (seguras de exponer, protegidas por RLS).
# Copia este archivo a .env y rellena con los valores de tu proyecto Supabase.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# NOTA: la Groq API key NO va aquí ni en la nube — cada usuario la introduce en
# Ajustes y se guarda solo en el config.json local de la app.
