{
  "name": "call-transcriber-app",
  "private": true,
  "version": "1.0.2",
  "description": "Graba, transcribe y resume entrevistas de trabajo con IA.",
  "author": "Call Transcriber",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on http-get://localhost:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build": "tsc -b && vite build",
    "desktop:build": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "release:win": "npm run build && electron-builder --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.calltranscriber.desktop",
    "productName": "Call Transcriber",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "publisherName": "Call Transcriber"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Call Transcriber"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Vankish",
        "repo": "Call-transcriber"
      }
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
