{
  "name": "call-transcriber-app",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on http-get://localhost:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build": "tsc -b && vite build",
    "desktop:build": "npm run build && electron .",
    "dist:win": "npm run build && electron-packager . \"Call Transcriber\" --platform=win32 --arch=x64 --overwrite --out=release --prune=true --asar --asar-unpack=\"**/ffmpeg-static/**\"",
    "package:win": "npm run build && electron-packager . \"Call Transcriber\" --platform=win32 --arch=x64 --overwrite --out=release --prune=true",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.calltranscriber.desktop",
    "productName": "Call Transcriber",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
